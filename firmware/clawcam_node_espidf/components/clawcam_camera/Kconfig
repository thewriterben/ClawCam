menu "ClawCam Camera"

config CLAWCAM_CAMERA_USE_ESP_CAMERA
    bool "Enable esp32-camera hardware capture path"
    default n
    help
        Enable this only when the espressif/esp32-camera component is available
        in the ESP-IDF project. When disabled, the ClawCam camera component
        initializes in scaffold mode and capture returns ESP_ERR_NOT_SUPPORTED.

config CLAWCAM_CAMERA_SMOKE_TEST_ON_BOOT
    bool "Run one camera capture smoke test at boot"
    default n
    depends on CLAWCAM_CAMERA_USE_ESP_CAMERA
    help
        Run a single JPEG capture after camera initialization, log the frame
        size, and release the framebuffer. This is intended for bench testing
        the first ESP32-S3-EYE hardware camera path.

config CLAWCAM_CAMERA_SMOKE_TEST_RETRY_COUNT
    int "Camera smoke test retry count"
    default 1
    range 1 5
    depends on CLAWCAM_CAMERA_SMOKE_TEST_ON_BOOT
    help
        Number of capture attempts during the boot-time smoke test.

endmenu
