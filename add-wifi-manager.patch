diff --git a/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/Kconfig b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/Kconfig
new file mode 100644
index 0000000..80c6544
--- /dev/null
+++ b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/Kconfig
@@ -0,0 +1,60 @@
+menu "ClawCam Wi-Fi Manager"
+
+config CLAWCAM_WIFI_ENABLED
+    bool "Enable ClawCam Wi-Fi STA path"
+    default n
+    help
+        Enable the firmware Wi-Fi station path. When disabled, the Wi-Fi
+        manager initializes in offline-first scaffold mode and connection
+        attempts return ESP_ERR_NOT_SUPPORTED. SD-card artifact creation
+        (media, metadata, event JSON) is intentionally independent from this
+        setting so the device continues to log captures when the network is
+        unavailable.
+
+config CLAWCAM_WIFI_PROVISIONING_MODE
+    bool "Boot into provisioning mode instead of STA"
+    default n
+    depends on CLAWCAM_WIFI_ENABLED
+    help
+        Mark the manager as provisioning-mode at boot. The provisioning
+        transport is not yet implemented; this flag is exposed so future
+        provisioning code can be added without breaking the public API.
+        While set, clawcam_wifi_connect() returns ESP_ERR_NOT_SUPPORTED and
+        firmware should treat the device as offline.
+
+config CLAWCAM_WIFI_SSID
+    string "Wi-Fi STA SSID"
+    default ""
+    depends on CLAWCAM_WIFI_ENABLED
+    help
+        SSID used for the station-mode connection attempt.
+
+config CLAWCAM_WIFI_PASSWORD
+    string "Wi-Fi STA password"
+    default ""
+    depends on CLAWCAM_WIFI_ENABLED
+    help
+        Password for the station-mode connection. Leave empty for open
+        networks. Values should be supplied via build secrets or a board
+        sdkconfig, not committed.
+
+config CLAWCAM_WIFI_CONNECT_TIMEOUT_MS
+    int "Wi-Fi connect timeout (ms)"
+    default 10000
+    range 1000 120000
+    depends on CLAWCAM_WIFI_ENABLED
+    help
+        Maximum time clawcam_wifi_connect() blocks before returning
+        ESP_ERR_TIMEOUT. The firmware should treat any non-OK result as
+        offline and continue with SD-card-first behavior.
+
+config CLAWCAM_WIFI_MAX_RETRIES
+    int "Wi-Fi connect max retries"
+    default 3
+    range 0 20
+    depends on CLAWCAM_WIFI_ENABLED
+    help
+        Number of reconnect attempts on STA disconnect before reporting
+        failure for the current connect call.
+
+endmenu
diff --git a/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/clawcam_wifi_manager.c b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/clawcam_wifi_manager.c
new file mode 100644
index 0000000..7d8b06b
--- /dev/null
+++ b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/clawcam_wifi_manager.c
@@ -0,0 +1,320 @@
+#include "clawcam_wifi_manager.h"
+
+#include <string.h>
+#include "esp_log.h"
+#include "esp_timer.h"
+
+#if defined(__has_include)
+#  if __has_include("freertos/FreeRTOS.h") && __has_include("freertos/event_groups.h")
+#    include "freertos/FreeRTOS.h"
+#    include "freertos/event_groups.h"
+#    include "freertos/task.h"
+#    define CLAWCAM_HAVE_FREERTOS 1
+#  else
+#    define CLAWCAM_HAVE_FREERTOS 0
+#  endif
+#  if __has_include("esp_wifi.h") && __has_include("esp_event.h") && __has_include("esp_netif.h")
+#    include "esp_event.h"
+#    include "esp_netif.h"
+#    include "esp_wifi.h"
+#    define CLAWCAM_HAVE_ESP_WIFI 1
+#  else
+#    define CLAWCAM_HAVE_ESP_WIFI 0
+#  endif
+#else
+#  define CLAWCAM_HAVE_FREERTOS 0
+#  define CLAWCAM_HAVE_ESP_WIFI 0
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_ENABLED
+#define CONFIG_CLAWCAM_WIFI_ENABLED 0
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_PROVISIONING_MODE
+#define CONFIG_CLAWCAM_WIFI_PROVISIONING_MODE 0
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_SSID
+#define CONFIG_CLAWCAM_WIFI_SSID ""
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_PASSWORD
+#define CONFIG_CLAWCAM_WIFI_PASSWORD ""
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_CONNECT_TIMEOUT_MS
+#define CONFIG_CLAWCAM_WIFI_CONNECT_TIMEOUT_MS 10000
+#endif
+
+#ifndef CONFIG_CLAWCAM_WIFI_MAX_RETRIES
+#define CONFIG_CLAWCAM_WIFI_MAX_RETRIES 3
+#endif
+
+static const char *TAG = "clawcam_wifi";
+
+#define CLAWCAM_WIFI_CONNECTED_BIT BIT0
+#define CLAWCAM_WIFI_FAILED_BIT    BIT1
+
+static clawcam_wifi_config_t s_config = {0};
+static bool s_initialized = false;
+static bool s_connected = false;
+static uint8_t s_retry_count = 0;
+static uint32_t s_last_connect_duration_ms = 0;
+static int s_last_rssi = 0;
+
+#if CONFIG_CLAWCAM_WIFI_ENABLED && CLAWCAM_HAVE_ESP_WIFI && CLAWCAM_HAVE_FREERTOS
+static EventGroupHandle_t s_wifi_event_group = NULL;
+static esp_event_handler_instance_t s_handler_any_id = NULL;
+static esp_event_handler_instance_t s_handler_got_ip = NULL;
+
+static void wifi_event_handler(void *arg, esp_event_base_t event_base,
+                               int32_t event_id, void *event_data)
+{
+    (void)arg;
+    if (event_base == WIFI_EVENT && event_id == WIFI_EVENT_STA_START) {
+        esp_wifi_connect();
+    } else if (event_base == WIFI_EVENT && event_id == WIFI_EVENT_STA_DISCONNECTED) {
+        s_connected = false;
+        if (s_retry_count < s_config.max_retries) {
+            s_retry_count++;
+            ESP_LOGW(TAG, "Wi-Fi disconnected; retry %u/%u", s_retry_count, s_config.max_retries);
+            esp_wifi_connect();
+        } else {
+            ESP_LOGE(TAG, "Wi-Fi retries exhausted (%u); giving up for this attempt", s_config.max_retries);
+            if (s_wifi_event_group) {
+                xEventGroupSetBits(s_wifi_event_group, CLAWCAM_WIFI_FAILED_BIT);
+            }
+        }
+    } else if (event_base == IP_EVENT && event_id == IP_EVENT_STA_GOT_IP) {
+        s_connected = true;
+        ESP_LOGI(TAG, "Wi-Fi got IP");
+        if (s_wifi_event_group) {
+            xEventGroupSetBits(s_wifi_event_group, CLAWCAM_WIFI_CONNECTED_BIT);
+        }
+    }
+}
+#endif
+
+esp_err_t clawcam_wifi_default_config(clawcam_wifi_config_t *config)
+{
+    if (config == NULL) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    if (CONFIG_CLAWCAM_WIFI_PROVISIONING_MODE) {
+        config->mode = CLAWCAM_WIFI_MODE_PROVISIONING;
+    } else if (CONFIG_CLAWCAM_WIFI_ENABLED) {
+        config->mode = CLAWCAM_WIFI_MODE_STA;
+    } else {
+        config->mode = CLAWCAM_WIFI_MODE_DISABLED;
+    }
+    config->ssid = CONFIG_CLAWCAM_WIFI_SSID;
+    config->password = CONFIG_CLAWCAM_WIFI_PASSWORD;
+    config->connect_timeout_ms = CONFIG_CLAWCAM_WIFI_CONNECT_TIMEOUT_MS;
+    config->max_retries = CONFIG_CLAWCAM_WIFI_MAX_RETRIES;
+    return ESP_OK;
+}
+
+esp_err_t clawcam_wifi_init(const clawcam_wifi_config_t *config)
+{
+    if (config == NULL) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    s_config = *config;
+    s_connected = false;
+    s_retry_count = 0;
+    s_last_connect_duration_ms = 0;
+    s_last_rssi = 0;
+
+    if (s_config.mode == CLAWCAM_WIFI_MODE_DISABLED) {
+        s_initialized = true;
+        ESP_LOGI(TAG, "Wi-Fi disabled; ClawCam remains offline-first and SD artifacts continue independently");
+        return ESP_OK;
+    }
+
+    if (s_config.mode == CLAWCAM_WIFI_MODE_PROVISIONING) {
+        s_initialized = true;
+        ESP_LOGW(TAG, "Wi-Fi provisioning mode requested; provisioning transport not yet implemented, treat as offline until completed");
+        return ESP_OK;
+    }
+
+#if CONFIG_CLAWCAM_WIFI_ENABLED && CLAWCAM_HAVE_ESP_WIFI && CLAWCAM_HAVE_FREERTOS
+    s_wifi_event_group = xEventGroupCreate();
+    if (s_wifi_event_group == NULL) {
+        return ESP_ERR_NO_MEM;
+    }
+
+    esp_err_t err = esp_netif_init();
+    if (err != ESP_OK && err != ESP_ERR_INVALID_STATE) {
+        return err;
+    }
+    err = esp_event_loop_create_default();
+    if (err != ESP_OK && err != ESP_ERR_INVALID_STATE) {
+        return err;
+    }
+    esp_netif_create_default_wifi_sta();
+
+    wifi_init_config_t init_cfg = WIFI_INIT_CONFIG_DEFAULT();
+    err = esp_wifi_init(&init_cfg);
+    if (err != ESP_OK) {
+        return err;
+    }
+
+    err = esp_event_handler_instance_register(WIFI_EVENT, ESP_EVENT_ANY_ID,
+                                              &wifi_event_handler, NULL,
+                                              &s_handler_any_id);
+    if (err != ESP_OK) {
+        return err;
+    }
+    err = esp_event_handler_instance_register(IP_EVENT, IP_EVENT_STA_GOT_IP,
+                                              &wifi_event_handler, NULL,
+                                              &s_handler_got_ip);
+    if (err != ESP_OK) {
+        return err;
+    }
+
+    wifi_config_t wifi_cfg = {0};
+    strlcpy((char *)wifi_cfg.sta.ssid, s_config.ssid ? s_config.ssid : "", sizeof(wifi_cfg.sta.ssid));
+    strlcpy((char *)wifi_cfg.sta.password, s_config.password ? s_config.password : "", sizeof(wifi_cfg.sta.password));
+    wifi_cfg.sta.threshold.authmode = WIFI_AUTH_WPA2_PSK;
+    err = esp_wifi_set_mode(WIFI_MODE_STA);
+    if (err != ESP_OK) {
+        return err;
+    }
+    err = esp_wifi_set_config(WIFI_IF_STA, &wifi_cfg);
+    if (err != ESP_OK) {
+        return err;
+    }
+
+    s_initialized = true;
+    ESP_LOGI(TAG, "Wi-Fi manager initialized for SSID '%s' (timeout=%ums retries=%u)",
+             (const char *)wifi_cfg.sta.ssid,
+             (unsigned)s_config.connect_timeout_ms,
+             (unsigned)s_config.max_retries);
+    return ESP_OK;
+#else
+    s_initialized = true;
+    ESP_LOGW(TAG, "Wi-Fi manager initialized in scaffold mode; enable CONFIG_CLAWCAM_WIFI_ENABLED with ESP-IDF Wi-Fi support for real connection attempts");
+    return ESP_OK;
+#endif
+}
+
+esp_err_t clawcam_wifi_connect(void)
+{
+    if (!s_initialized) {
+        return ESP_ERR_INVALID_STATE;
+    }
+    if (s_config.mode == CLAWCAM_WIFI_MODE_DISABLED) {
+        return ESP_ERR_NOT_SUPPORTED;
+    }
+    if (s_config.mode == CLAWCAM_WIFI_MODE_PROVISIONING) {
+        ESP_LOGW(TAG, "Wi-Fi connect requested while in provisioning mode; no STA credentials applied");
+        return ESP_ERR_NOT_SUPPORTED;
+    }
+
+#if CONFIG_CLAWCAM_WIFI_ENABLED && CLAWCAM_HAVE_ESP_WIFI && CLAWCAM_HAVE_FREERTOS
+    if (s_wifi_event_group == NULL) {
+        return ESP_ERR_INVALID_STATE;
+    }
+    xEventGroupClearBits(s_wifi_event_group, CLAWCAM_WIFI_CONNECTED_BIT | CLAWCAM_WIFI_FAILED_BIT);
+    s_retry_count = 0;
+
+    int64_t start_us = esp_timer_get_time();
+    esp_err_t err = esp_wifi_start();
+    if (err != ESP_OK && err != ESP_ERR_WIFI_CONN) {
+        return err;
+    }
+
+    TickType_t timeout_ticks = pdMS_TO_TICKS(s_config.connect_timeout_ms > 0
+                                                 ? s_config.connect_timeout_ms
+                                                 : CONFIG_CLAWCAM_WIFI_CONNECT_TIMEOUT_MS);
+    EventBits_t bits = xEventGroupWaitBits(s_wifi_event_group,
+                                           CLAWCAM_WIFI_CONNECTED_BIT | CLAWCAM_WIFI_FAILED_BIT,
+                                           pdFALSE, pdFALSE, timeout_ticks);
+    s_last_connect_duration_ms = (uint32_t)((esp_timer_get_time() - start_us) / 1000);
+
+    if (bits & CLAWCAM_WIFI_CONNECTED_BIT) {
+        wifi_ap_record_t ap = {0};
+        if (esp_wifi_sta_get_ap_info(&ap) == ESP_OK) {
+            s_last_rssi = ap.rssi;
+        }
+        ESP_LOGI(TAG, "Wi-Fi connected in %ums (rssi=%d)", (unsigned)s_last_connect_duration_ms, s_last_rssi);
+        return ESP_OK;
+    }
+    if (bits & CLAWCAM_WIFI_FAILED_BIT) {
+        ESP_LOGW(TAG, "Wi-Fi connect failed after %u retries", (unsigned)s_retry_count);
+        return ESP_FAIL;
+    }
+    ESP_LOGW(TAG, "Wi-Fi connect timed out after %ums", (unsigned)s_config.connect_timeout_ms);
+    return ESP_ERR_TIMEOUT;
+#else
+    s_retry_count++;
+    ESP_LOGW(TAG, "Wi-Fi connect requested but hardware path is scaffolded; SD-card artifacts continue independently");
+    return ESP_ERR_NOT_SUPPORTED;
+#endif
+}
+
+bool clawcam_wifi_is_connected(void)
+{
+    return s_connected;
+}
+
+esp_err_t clawcam_wifi_get_status(clawcam_wifi_status_t *status)
+{
+    if (status == NULL) {
+        return ESP_ERR_INVALID_ARG;
+    }
+    status->initialized = s_initialized;
+    status->connected = s_connected;
+    status->mode = s_config.mode;
+    status->rssi = s_last_rssi;
+    status->retry_count = s_retry_count;
+    status->last_connect_duration_ms = s_last_connect_duration_ms;
+    if (!s_initialized) {
+        status->status = "not_initialized";
+    } else if (s_config.mode == CLAWCAM_WIFI_MODE_DISABLED) {
+        status->status = "disabled";
+    } else if (s_config.mode == CLAWCAM_WIFI_MODE_PROVISIONING) {
+        status->status = "provisioning";
+    } else if (s_connected) {
+        status->status = "connected";
+    } else {
+        status->status = "offline";
+    }
+    return ESP_OK;
+}
+
+esp_err_t clawcam_wifi_disconnect(void)
+{
+#if CONFIG_CLAWCAM_WIFI_ENABLED && CLAWCAM_HAVE_ESP_WIFI && CLAWCAM_HAVE_FREERTOS
+    if (s_initialized && s_config.mode == CLAWCAM_WIFI_MODE_STA) {
+        esp_wifi_disconnect();
+    }
+#endif
+    s_connected = false;
+    return ESP_OK;
+}
+
+esp_err_t clawcam_wifi_deinit(void)
+{
+#if CONFIG_CLAWCAM_WIFI_ENABLED && CLAWCAM_HAVE_ESP_WIFI && CLAWCAM_HAVE_FREERTOS
+    if (s_initialized && s_config.mode == CLAWCAM_WIFI_MODE_STA) {
+        esp_wifi_stop();
+        esp_wifi_deinit();
+    }
+    if (s_handler_any_id) {
+        esp_event_handler_instance_unregister(WIFI_EVENT, ESP_EVENT_ANY_ID, s_handler_any_id);
+        s_handler_any_id = NULL;
+    }
+    if (s_handler_got_ip) {
+        esp_event_handler_instance_unregister(IP_EVENT, IP_EVENT_STA_GOT_IP, s_handler_got_ip);
+        s_handler_got_ip = NULL;
+    }
+    if (s_wifi_event_group) {
+        vEventGroupDelete(s_wifi_event_group);
+        s_wifi_event_group = NULL;
+    }
+#endif
+    s_initialized = false;
+    s_connected = false;
+    return ESP_OK;
+}
diff --git a/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/include/clawcam_wifi_manager.h b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/include/clawcam_wifi_manager.h
new file mode 100644
index 0000000..159ccfd
--- /dev/null
+++ b/firmware/clawcam_node_espidf/components/clawcam_wifi_manager/include/clawcam_wifi_manager.h
@@ -0,0 +1,91 @@
+#pragma once
+
+#include <stdbool.h>
+#include <stdint.h>
+#include "esp_err.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/*
+ * ClawCam Wi-Fi manager
+ *
+ * This component is intentionally separate from the gateway client and from
+ * SD/FATFS artifact creation. SD-card media, metadata, and event artifacts
+ * MUST remain the offline source of truth and are not gated by Wi-Fi state.
+ * The Wi-Fi manager is only consulted before optional network operations such
+ * as a gateway HTTP upload.
+ *
+ * Modes:
+ *   DISABLED      - Wi-Fi is intentionally off; all connect calls return
+ *                   ESP_ERR_NOT_SUPPORTED and ClawCam remains offline-first.
+ *   STA           - Station mode using configured SSID/password.
+ *   PROVISIONING  - Reserved provisioning entry point. The provisioning
+ *                   transport itself is not implemented in this scaffold;
+ *                   the mode is exposed so that firmware can signal the
+ *                   intent and so future provisioning code can be added
+ *                   without breaking the public API.
+ */
+typedef enum {
+    CLAWCAM_WIFI_MODE_DISABLED = 0,
+    CLAWCAM_WIFI_MODE_STA = 1,
+    CLAWCAM_WIFI_MODE_PROVISIONING = 2,
+} clawcam_wifi_mode_t;
+
+typedef struct {
+    clawcam_wifi_mode_t mode;
+    const char *ssid;
+    const char *password;
+    uint32_t connect_timeout_ms;
+    uint8_t max_retries;
+} clawcam_wifi_config_t;
+
+typedef struct {
+    bool initialized;
+    bool connected;
+    clawcam_wifi_mode_t mode;
+    int rssi;
+    uint8_t retry_count;
+    uint32_t last_connect_duration_ms;
+    const char *status;
+} clawcam_wifi_status_t;
+
+/*
+ * Populate config from Kconfig defaults. Safe to call before init.
+ */
+esp_err_t clawcam_wifi_default_config(clawcam_wifi_config_t *config);
+
+/*
+ * Initialize the Wi-Fi manager. Does not start a connection attempt. When the
+ * ESP-IDF Wi-Fi stack is not available (host builds, scaffold mode), this
+ * still returns ESP_OK so SD-card persistence stays unaffected by Wi-Fi.
+ */
+esp_err_t clawcam_wifi_init(const clawcam_wifi_config_t *config);
+
+/*
+ * Block until the Wi-Fi manager either reports a connection or exhausts
+ * config->max_retries / config->connect_timeout_ms. Returns ESP_ERR_TIMEOUT
+ * if the timeout expires without a connection and ESP_ERR_NOT_SUPPORTED if
+ * the manager is in DISABLED mode. Callers should treat any non-OK result
+ * as "no network" and continue with SD-card-first behavior.
+ */
+esp_err_t clawcam_wifi_connect(void);
+
+/*
+ * Lightweight, non-blocking status check.
+ */
+bool clawcam_wifi_is_connected(void);
+
+/*
+ * Report current connection health. Always populates the status struct, even
+ * when Wi-Fi is disabled.
+ */
+esp_err_t clawcam_wifi_get_status(clawcam_wifi_status_t *status);
+
+esp_err_t clawcam_wifi_disconnect(void);
+esp_err_t clawcam_wifi_deinit(void);
+
+#ifdef __cplusplus
+}
+#endif
