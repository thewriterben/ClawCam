+def test_wifi_manager_component_exposes_offline_first_api() -> None:
+    wifi_header = (ROOT / "firmware/clawcam_node_espidf/components/clawcam_wifi_manager/include/clawcam_wifi_manager.h").read_text(encoding="utf-8")
+    wifi_source = (ROOT / "firmware/clawcam_node_espidf/components/clawcam_wifi_manager/clawcam_wifi_manager.c").read_text(encoding="utf-8")
+    wifi_kconfig = (ROOT / "firmware/clawcam_node_espidf/components/clawcam_wifi_manager/Kconfig").read_text(encoding="utf-8")
+    wifi_cmake = (ROOT / "firmware/clawcam_node_espidf/components/clawcam_wifi_manager/CMakeLists.txt").read_text(encoding="utf-8")
+
+    for symbol in [
+        "clawcam_wifi_config_t",
+        "clawcam_wifi_status_t",
+        "CLAWCAM_WIFI_MODE_DISABLED",
+        "CLAWCAM_WIFI_MODE_STA",
+        "CLAWCAM_WIFI_MODE_PROVISIONING",
+        "clawcam_wifi_default_config",
+        "clawcam_wifi_init",
+        "clawcam_wifi_connect",
+        "clawcam_wifi_is_connected",
+        "clawcam_wifi_get_status",
+        "clawcam_wifi_disconnect",
+        "clawcam_wifi_deinit",
+        "last_connect_duration_ms",
+    ]:
+        assert symbol in wifi_header, f"missing {symbol} in clawcam_wifi_manager.h"
+
+    assert "CONFIG_CLAWCAM_WIFI_ENABLED" in wifi_source
+    assert "CONFIG_CLAWCAM_WIFI_PROVISIONING_MODE" in wifi_source
+    assert "esp_wifi_init" in wifi_source
+    assert "esp_wifi_connect" in wifi_source
+    assert "WIFI_EVENT_STA_DISCONNECTED" in wifi_source
+    assert "IP_EVENT_STA_GOT_IP" in wifi_source
+    assert "ESP_ERR_TIMEOUT" in wifi_source
+    assert "ESP_ERR_NOT_SUPPORTED" in wifi_source
+    # The manager must not depend on SD-card persistence and must declare
+    # offline-first behavior in its log messages.
+
