+        return false;
+    }
+    if (wifi_status.mode == CLAWCAM_WIFI_MODE_PROVISIONING) {
+        ESP_LOGW(TAG, "Wi-Fi in provisioning mode; skipping gateway upload, SD event remains source of truth");
+        return false;
+    }
+    if (!wifi_status.connected) {
+        esp_err_t err = clawcam_wifi_connect();
+        if (err != ESP_OK) {
+            ESP_LOGW(TAG, "Wi-Fi connect before upload failed: %s; SD event remains source of truth", esp_err_to_name(err));
+            return false;
+        }
+    }
+    clawcam_wifi_get_status(&wifi_status);
+    ESP_LOGI(TAG, "Wi-Fi health: status=%s rssi=%d retry=%u connect_ms=%u",
+             wifi_status.status,
+             wifi_status.rssi,
+             (unsigned)wifi_status.retry_count,
+             (unsigned)wifi_status.last_connect_duration_ms);
+    return wifi_status.connected;
 }
 
