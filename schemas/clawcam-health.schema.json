{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clawcam.dev/schemas/clawcam-health.schema.json",
  "title": "ClawCam Health",
  "type": "object",
  "required": ["device_id", "timestamp", "status"],
  "additionalProperties": false,
  "properties": {
    "device_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "status": {"type": "string", "enum": ["ok", "warning", "critical", "offline", "unknown"]},
    "uptime_seconds": {"type": ["integer", "null"], "minimum": 0},
    "battery": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "voltage": {"type": "number"},
        "percentage": {"type": "integer", "minimum": 0, "maximum": 100},
        "charging": {"type": "boolean"},
        "estimated_hours_remaining": {"type": ["number", "null"]}
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "free_bytes": {"type": "integer", "minimum": 0},
        "used_bytes": {"type": "integer", "minimum": 0},
        "total_bytes": {"type": "integer", "minimum": 0},
        "media_count": {"type": "integer", "minimum": 0}
      }
    },
    "radio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rssi": {"type": ["number", "null"]},
        "snr": {"type": ["number", "null"]},
        "packet_loss": {"type": ["number", "null"], "minimum": 0},
        "last_seen_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "temperature_c": {"type": "number"},
        "humidity_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "pressure_hpa": {"type": "number"}
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "additionalProperties": false,
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warning", "critical"]}
        }
      },
      "default": []
    },
    "metadata": {"type": "object", "additionalProperties": true, "default": {}}
  }
}
